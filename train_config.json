{
    "job_name": "smolvla_finetune",
    "dataset": {
        "repo_id": "YOUR_DATASET_NAME",
        "root": "/smolvla/datasets",
        "deltatimestamps_while_loading": false
    },
    "env": null,
    "eval": {
        "n_episodes": 10,
        "frequency": 5000,
        "batch_size": 8
    },
    "policy": {
        "type": "smolvla",
        "pretrained_path": "/smolvla/models/smolvla_base",
        "device": "cuda",
        "use_amp": false,
        "freeze_vision_encoder": true,
        "train_expert_only": true,
        "train_state_proj": true,
        "chunk_size": 50,
        "n_action_steps": 50,
        "n_obs_steps": 1,
        "num_steps": 10,
        "use_cache": true,
        "tokenizer_max_length": 48
    },
    "optimizer": {
        "type": "adamw",
        "lr": 0.0001,
        "betas": [0.9, 0.95],
        "eps": 1e-08,
        "weight_decay": 1e-10,
        "grad_clip_norm": 10
    },
    "scheduler": {
        "type": "cosine",
        "warmup_steps": 1000,
        "decay_steps": 30000,
        "decay_lr": 2.5e-06
    },
    "batch_size": 8,
    "num_workers": 4,
    "steps": 50000,
    "log_freq": 50,
    "save_freq": 5000,
    "save_checkpoint": true,
    "seed": 42,
    "wandb": {
        "enable": false,
        "project": "smolvla",
        "entity": null
    }
}
